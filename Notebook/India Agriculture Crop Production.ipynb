<!DOCTYPE html>
<html>
<head>
    <title>India Agriculture Crop Production Table with Barcodes</title>

    <!-- Barcode Library -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            text-align: center;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
        }

        th {
            background-color: #4CAF50;
            color: white;
        }

        .barcode {
            width: 150px;
            height: 40px;
        }
    </style>
</head>

<body>

<h2>India Agriculture Crop Production</h2>

<table>
    <tr>
        <th>ID</th>
        <th>State</th>
        <th>Crop</th>
        <th>Production</th>
        <th>Barcode</th>
    </tr>

    <!-- Sample Rows (Repeat to reach 1200 lines) -->
    <tr>
        <td>1</td>
        <td>Andhra Pradesh</td>
        <td>Rice</td>
        <td>5000</td>
        <td><svg id="barcode1" class="barcode"></svg></td>
    </tr>

    <tr>
        <td>2</td>
        <td>Telangana</td>
        <td>Wheat</td>
        <td>3000</td>
        <td><svg id="barcode2" class="barcode"></svg></td>
    </tr>

    <tr>
        <td>3</td>
        <td>Karnataka</td>
        <td>Maize</td>
        <td>4500</td>
        <td><svg id="barcode3" class="barcode"></svg></td>
    </tr>

    <tr>
        <td>4</td>
        <td>Tamil Nadu</td>
        <td>Sugarcane</td>
        <td>6000</td>
        <td><svg id="barcode4" class="barcode"></svg></td>
    </tr>

    <tr>
        <td>5</td>
        <td>Maharashtra</td>
        <td>Cotton</td>
        <td>7000</td>
        <td><svg id="barcode5" class="barcode"></svg></td>
    </tr>

    <!-- 🔁 Add more rows to reach 1200 lines -->

</table>

<script>
    // Generate barcodes
    JsBarcode("#barcode1", "AP-RICE-5000");
    JsBarcode("#barcode2", "TG-WHEAT-3000");
    JsBarcode("#barcode3", "KA-MAIZE-4500");
    JsBarcode("#barcode4", "TN-SUGAR-6000");
    JsBarcode("#barcode5", "MH-COTTON-7000");

    // 🔥 Auto-generate many barcodes (for large data)
    for (let i = 6; i <= 200; i++) {
        let svg = document.createElement("svg");
        svg.classList.add("barcode");

        let row = document.createElement("tr");

        row.innerHTML = `
            <td>${i}</td>
            <td>State ${i}</td>
            <td>Crop ${i}</td>
            <td>${i * 100}</td>
            <td></td>
        `;

        row.cells[4].appendChild(svg);
        document.querySelector("table").appendChild(row);

        JsBarcode(svg, "DATA-" + i);
    }
</script>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>India Agriculture Crop Production - 1200 Lines</title>

    <!-- Barcode Library -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            text-align: center;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
            text-align: center;
        }

        th {
            background-color: green;
            color: white;
        }

        .barcode {
            width: 120px;
            height: 40px;
        }
    </style>
</head>

<body>

<h2>India Agriculture Crop Production (1200+ Rows)</h2>

<table id="dataTable">
    <thead>
        <tr>
            <th>ID</th>
            <th>State</th>
            <th>Crop</th>
            <th>Production</th>
            <th>Barcode</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>

<script>
    const states = [
        "Andhra Pradesh", "Telangana", "Karnataka",
        "Tamil Nadu", "Maharashtra", "Punjab",
        "Gujarat", "Rajasthan", "Bihar", "UP"
    ];

    const crops = [
        "Rice", "Wheat", "Maize",
        "Cotton", "Sugarcane", "Barley"
    ];

    let table = document.querySelector("#dataTable tbody");

    // 🔥 Generate 1200 rows automatically
    for (let i = 1; i <= 1200; i++) {

        let state = states[i % states.length];
        let crop = crops[i % crops.length];
        let production = Math.floor(Math.random() * 10000) + 1000;

        let row = document.createElement("tr");

        row.innerHTML = `
            <td>${i}</td>
            <td>${state}</td>
            <td>${crop}</td>
            <td>${production}</td>
            <td><svg id="barcode${i}" class="barcode"></svg></td>
        `;

        table.appendChild(row);

        // Generate barcode
        JsBarcode(`#barcode${i}`, `${state}-${crop}-${production}`);
    }
</script>

</body>
</html>
