# ================================
# 1. IMPORT LIBRARIES
# ================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# Display all columns
pd.set_option('display.max_columns', None)


# ================================
# 2. LOAD DATASET
# ================================
# Change path if needed
df = pd.read_csv("crop_production.csv")

print("First 5 rows:")
display(df.head())


# ================================
# 3. BASIC INFORMATION
# ================================
print("Shape:", df.shape)
print("Columns:", df.columns)

print("\nDataset Info:")
df.info()


# ================================
# 4. DATA CLEANING
# ================================
# Remove missing values
df = df.dropna()

# Reset index
df.reset_index(drop=True, inplace=True)

print("\nAfter cleaning:")
display(df.head())


# ================================
# 5. SELECT REQUIRED COLUMNS
# ================================
df = df[['State_Name', 'Crop', 'Production']]

print("\nSelected Columns:")
display(df.head(10))


# ================================
# 6. GROUP BY STATE
# ================================
state_prod = df.groupby('State_Name')['Production'].sum().reset_index()

print("\nProduction by State:")
display(state_prod.head())


# ================================
# 7. TOP 10 STATES
# ================================
top_states = state_prod.sort_values(by='Production', ascending=False).head(10)

print("\nTop 10 States:")
display(top_states)


# ================================
# 8. CROP-WISE PRODUCTION
# ================================
crop_prod = df.groupby('Crop')['Production'].sum().reset_index()

print("\nCrop-wise Production:")
display(crop_prod.head())


# ================================
# 9. PIVOT TABLE
# ================================
pivot = pd.pivot_table(
    df,
    values='Production',
    index='State_Name',
    columns='Crop',
    aggfunc='sum'
)

print("\nPivot Table:")
display(pivot.head())


# ================================
# 10. BAR GRAPH
# ================================
plt.figure()
top_states.plot(kind='bar', x='State_Name', y='Production')

plt.title("Top 10 States by Production")
plt.xlabel("State")
plt.ylabel("Production")
plt.xticks(rotation=45)

plt.show()


# ================================
# 11. INSTALL BARCODE LIBRARY
# ================================
!pip install python-barcode pillow


# ================================
# 12. GENERATE BARCODES
# ================================
import barcode
from barcode.writer import ImageWriter

print("\nGenerating barcodes...")

for i in range(10):
    data = f"{df.iloc[i]['State_Name']}-{df.iloc[i]['Crop']}-{df.iloc[i]['Production']}"
    
    code = barcode.get('code128', data, writer=ImageWriter())
    filename = code.save(f'barcode_{i}')
    
    print(f"Saved: {filename}")


# ================================
# 13. DISPLAY BARCODES
# ================================
from IPython.display import Image, display

print("\nDisplaying barcodes:")

