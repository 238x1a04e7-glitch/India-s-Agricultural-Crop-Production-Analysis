<!DOCTYPE html>
<html>
<head>
    <title>India Agriculture Crop Production - 1200 Lines</title>

    <!-- Barcode Library -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            text-align: center;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        th, td {
            border: 1px solid black;
            padding: 6px;
            text-align: center;
        }

        th {
            background-color: green;
            color: white;
        }

        .barcode {
            width: 120px;
            height: 40px;
        }
    </style>
</head>

<body>

<h2>India Agriculture Crop Production (1200+ Rows)</h2>

<table id="dataTable">
    <thead>
        <tr>
            <th>ID</th>
            <th>State</th>
            <th>Crop</th>
            <th>Production</th>
            <th>Barcode</th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>

<script>
    const states = [
        "Andhra Pradesh", "Telangana", "Karnataka",
        "Tamil Nadu", "Maharashtra", "Punjab",
        "Gujarat", "Rajasthan", "Bihar", "UP"
    ];

    const crops = [
        "Rice", "Wheat", "Maize",
        "Cotton", "Sugarcane", "Barley"
    ];

    let table = document.querySelector("#dataTable tbody");

    // 🔥 Generate 1200 rows automatically
    for (let i = 1; i <= 1200; i++) {

        let state = states[i % states.length];
        let crop = crops[i % crops.length];
        let production = Math.floor(Math.random() * 10000) + 1000;

        let row = document.createElement("tr");

        row.innerHTML = `
            <td>${i}</td>
            <td>${state}</td>
            <td>${crop}</td>
            <td>${production}</td>
            <td><svg id="barcode${i}" class="barcode"></svg></td>
        `;

        table.appendChild(row);

        // Generate barcode
        JsBarcode(`#barcode${i}`, `${state}-${crop}-${production}`);
    }
</script>

</body>
</html>
